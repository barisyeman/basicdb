{
    "name": "barisyeman/basicdb",
    "type": "library",
    "description": "Lightweight, secure PDO query builder. A modernized fork of tayfunerbilen/basicdb with prepared-statement identifier whitelisting, PHP 8.1+ typing and transaction helpers.",
    "keywords": ["db", "pdo", "oop", "query-builder", "orm", "mysql"],
    "homepage": "https://github.com/barisyeman/basicdb",
    "license": "MIT",
    "authors": [
        {
            "name": "Tayfun Erbilen",
            "email": "tayfunerbilen@gmail.com",
            "homepage": "http://www.erbilen.net",
            "role": "Original author"
        },
        {
            "name": "Midori Kocak",
            "email": "mtkocak@gmail.com",
            "homepage": "http://www.mtkocak.com",
            "role": "Original author"
        },
        {
            "name": "Barış Yeman",
            "homepage": "https://github.com/barisyeman",
            "role": "Maintainer (2026 modernization)"
        }
    ],
    "require": {
        "php": ">=8.1",
        "ext-pdo": "*",
        "ext-pdo_mysql": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "BarisYeman\\BasicDB\\": "src/"
        }
    }
}
